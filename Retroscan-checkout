// Sökfunktion

function searchDTC(){

let code=document.getElementById("code").value.trim();

if(code.startsWith("0")){
code=code.replace(/^0+/,"");
}


let result=document.getElementById("result");


if(dtc[code]){

let d=dtc[code];


result.innerHTML=`

<div class="result">

<h2>DTC ${code} - ${d.name}</h2>

<p>${d.description}</p>


<h3>Vanliga orsaker:</h3>
<ul>
${d.causes.map(x=>"<li>"+x+"</li>").join("")}
</ul>


<h3>Kontrollera först:</h3>
<ul>
${d.check.map(x=>"<li>"+x+"</li>").join("")}
</ul>


<h3>Åtgärd:</h3>
<ul>
${d.repair.map(x=>"<li>"+x+"</li>").join("")}
</ul>


</div>

`;

}

else{

result.innerHTML=`

<div class="result">
Ingen felkod hittades.
<br><br>
Testa exempelvis: 32, 42 eller 45
</div>

`;

}

}

