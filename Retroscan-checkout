function searchDTC(){

let code=document.getElementById("code").value.trim();

let result=document.getElementById("result");


if(dtc[code]){

let d=dtc[code];

result.innerHTML=`

<div class="result">

<h2>DTC ${code} - ${d.name}</h2>

<p>${d.text}</p>

<h3>Kontrollera:</h3>

<ul>
${d.check.map(x=>"<li>"+x+"</li>").join("")}
</ul>


<h3>Åtgärd:</h3>

<ul>
${d.repair.map(x=>"<li>"+x+"</li>").join("")}
</ul>

</div>

`;

}

else{

result.innerHTML=
"<div class='result'>Ingen felkod hittades</div>";

}

